{
  "manifest_version": 3,
  "name": "Kalananti Presentation Timer",
  "version": "1.0",
  "description": "Menampilkan timer presentasi tersinkronisasi dari Juri.",
  "content_scripts": [
    {
      "matches": ["<all_urls>", "file:///*"],
      "css": ["content.css"],
      "js": ["content.js"],
      "all_frames": false
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["mqtt_client.html", "mqtt_client.js", "lib/mqttws31.min.js"],
      "matches": ["<all_urls>", "file:///*"]
    }
  ],
  "permissions": []
}
